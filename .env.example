# ShadowClaw — 환경변수 예시
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요. .env 는 git 에 커밋되지 않습니다.

# LLM API Key (둘 중 사용할 프로바이더만 설정)
# ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=

# 선택
# PORT=5052
# SHADOWCLAW_BASE_PATH=

# 워크스페이스 디렉터리 (OpenClaw 스타일). SOUL.md, USER.md, MEMORY.md, IDENTITY.md 를 이 경로에서 읽어 컨텍스트에 주입. 없으면 process.cwd()
# SHADOWCLAW_WORKSPACE_DIR=.
